		"eslint-plugin-obsidianmd": "^0.4.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"tsx": "^4.22.4",
		"typescript": "^5.6.3"
	},
	"dependencies": {
		"@deepgram/sdk": "^4.2.0",
		"@ffmpeg/ffmpeg": "^0.12.6",
